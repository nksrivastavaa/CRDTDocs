{
  "name": "collab-system",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade collaborative document SaaS monorepo",
  "workspaces": [
    "packages/types",
    "packages/common",
    "apps/api-gateway",
    "apps/frontend",
    "services/auth-service",
    "services/document-service",
    "services/collaboration-service",
    "services/notification-service"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "docker compose up --build",
    "down": "docker compose down",
    "lint": "npm run lint --workspaces --if-present",
    "seed": "node infra/docker/postgres/seed.js"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "rimraf": "^5.0.7",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5"
  }
}
